rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isManager() {
      return isSignedIn() && userDocExists() && userRole() == "manager";
    }

    function isOwnerAccount() {
      return isSignedIn() && userDocExists() &&
        (userRole() == "owner" || userRole() == "admin");
    }

    /// Manager or owner (legacy `admin` counts as owner).
    function isStaff() {
      return isManager() || isOwnerAccount();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();

      allow create: if isOwner(userId);
      allow update: if isStaff() || (
        isOwner(userId) &&
        request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["updatedAt", "todayStatus", "todayApprovalStatus", "todayCheckInDisplay"])
      );
      allow delete: if false;

      match /attendance/{dayId} {
        allow read: if isOwner(userId) || isStaff();

        allow create: if isOwner(userId);
        allow update: if isStaff() || isOwner(userId);
        allow delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isStaff();
        allow create: if isStaff();
        allow update: if isOwner(userId) || isStaff();
        allow delete: if false;
      }
    }

    // Worker self check-in + manager operational alerts.
    match /admin_notifications/{notificationId} {
      allow read: if isManager();
      allow create: if isSignedIn();
      allow update, delete: if isManager();
    }

    // Owner-only: manager marked someone present / late, etc.
    match /owner_notifications/{notificationId} {
      allow read: if isOwnerAccount();
      allow create: if isManager();
      allow update, delete: if isOwnerAccount();
    }

    match /funding_requests/{requestId} {
      allow create: if isManager() &&
        request.resource.data.managerId == request.auth.uid &&
        request.resource.data.status == "pending";

      allow read: if isOwnerAccount() ||
        (isManager() && resource.data.managerId == request.auth.uid);

      allow update: if isOwnerAccount();
      allow delete: if false;
    }

    match /login_events/{eventId} {
      allow create: if isSignedIn() &&
        request.resource.data.uid == request.auth.uid;
      allow read: if isStaff();
      allow update, delete: if false;
    }
  }
}
