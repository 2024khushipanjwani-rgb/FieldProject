rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Safely looks up the user's role from the database without throwing undefined errors
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
        : "none";
    }

    // Allows managers, owners, and legacy admins 
    function isStaff() {
      return isSignedIn() && (
        getUserRole() == "manager" || 
        getUserRole() == "owner" || 
        getUserRole() == "admin" ||
        getUserRole() == "Manager" // Added fallback for capitalized roles
      );
    }

    // 1. ALLOW SECRETS TO BE READ DURING SIGN-UP!
    match /system_config/{document} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      // Allow workers to read themselves, and Staff to read everyone
      allow read: if isOwner(userId) || isStaff();

      // Anyone can save their own profile initially during Signup
      allow create: if isOwner(userId);
      allow update: if isStaff() || (
        isOwner(userId) &&
        request.resource.data.diff(resource.data).changedKeys()
          // Added 'todayDateKey' ensuring Worker check-ins don't get blocked
          .hasOnly(["updatedAt", "todayStatus", "todayDateKey", "todayApprovalStatus", "todayCheckInDisplay"])
      );
      
      // ✅ This enables you to explicitly delete Workers from the Dashboard!
      allow delete: if isStaff();

      // ==========================================
      // ATTENDANCE SUBCOLLECTION 
      // ==========================================
      match /attendance/{dayId} {
        allow read: if isOwner(userId) || isStaff();
        allow create: if isOwner(userId) || isStaff();
        allow update: if isStaff() || isOwner(userId);
        
        // Let staff wipe subcollections if needed
        allow delete: if isStaff();
      }

      // ==========================================
      // WAGES SUBCOLLECTION (Fixed missing rules block!)
      // ==========================================
      match /wages/{wageId} {
        allow read: if isOwner(userId) || isStaff();
        allow create: if isStaff() || isOwner(userId);
        allow update: if isStaff() || isOwner(userId);
        
        // Let staff wipe subcollections if needed
        allow delete: if isStaff();
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(userId) || isStaff();
        allow create: if isStaff();
        allow update: if isOwner(userId) || isStaff();
        allow delete: if isStaff();
      }
    }

    // ✅ 'write' safely includes 'delete' - allows Managers to delete explicit old Funding requests natively!
    match /funding_requests/{document=**} {
      allow read, write: if isStaff();
    }
    
    match /requests/{document=**} {
      allow read, write: if isStaff();
    }
    
    match /notifications/{document=**} {
      allow read, write: if isStaff();
    }

    match /login_events/{eventId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isStaff();
      allow update, delete: if false;
    }

    // ==========================================
    // NOTIFICATION RULES
    // ==========================================
    match /admin_notifications/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /owner_notifications/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ==========================================
    // INVENTORY AND ORDERS
    // ==========================================
    match /inventory/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /orders/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
